{
  "name": "shopify-pulse/wp-connector",
  "description": "Shopify Pulse Connector — WooCommerce integration test suite.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0",
    "wp-phpunit/wp-phpunit": "^6.4"
  },
  "scripts": {
    "test": "phpunit",
    "build": "bin/build-zip.sh"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
